<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="100%" height="100%">
  <!-- Definições de Efeitos -->
  <defs>
    <!-- Gradiente de Brilho Neon para o Escudo -->
    <linearGradient id="neon-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#4ade80" />
      <stop offset="100%" stop-color="#22c55e" />
    </linearGradient>
    <!-- Sombra projetada para dar profundidade -->
    <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="12" result="blur" />
      <feComposite in="SourceGraphic" in2="blur" operator="over" />
    </filter>
  </defs>

  <!-- Fundo Sólido Escuro -->
  <rect width="512" height="512" rx="128" fill="#0b0f12" />

  <!-- Detalhe de Fundo: Listras de Relvado Minimalistas Subtis -->
  <g opacity="0.03">
    <rect x="0" y="0" width="512" height="102" fill="#ffffff" />
    <rect x="0" y="204" width="512" height="102" fill="#ffffff" />
    <rect x="0" y="408" width="512" height="104" fill="#ffffff" />
  </g>

  <!-- Corpo Central: Escudo e Monograma -->
  <g transform="translate(256, 240)" filter="url(#glow)">
    <!-- O Escudo do Pelada Pro -->
    <path d="M -140,-140 
             L 140,-140 
             C 140,-40 120,80 0,180 
             C -120,80 -140,-40 -140,-140 Z" 
          fill="#13191e" 
          stroke="url(#neon-grad)" 
          stroke-width="18" 
          stroke-linejoin="round" />

    <!-- Listra Diagonal Dinâmica Cortando o Escudo -->
    <path d="M -140,-40 L 140,-100" stroke="url(#neon-grad)" stroke-width="8" opacity="0.4" />

    <!-- O "P" Estilizado (Bold, Itálico e Atlético) -->
    <text x="-35" y="65" 
          font-family="'Impact', 'Arial Black', sans-serif" 
          font-size="210" 
          font-style="italic" 
          font-weight="900" 
          fill="url(#neon-grad)" 
          letter-spacing="2">P</text>
  </g>

  <!-- Pequena Estrela de Classificação no Topo (Elemento PRO / Ouro) -->
  <g transform="translate(256, 65) scale(0.9)">
    <polygon points="0,-18 5,-5 18,-5 8,4 12,17 0,9 -12,17 -8,4 -18,-5 -5,-5" fill="#eab308" />
  </g>
</svg>
