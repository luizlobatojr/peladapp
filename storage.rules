rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /avatars/{uid} {
      // Fotos de perfil são públicas pra leitura (aparecem pra todo mundo no app).
      allow read: if true;

      // Só o próprio usuário pode enviar/substituir a própria foto,
      // com limite de 5MB e obrigatoriamente um arquivo de imagem.
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Qualquer outro caminho fica bloqueado por padrão.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
